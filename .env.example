# OSPF Lint credentials file
# Copy this file to .env and fill in your credentials
# Used with: ospf-lint -e .env -f devices.txt

# Option 1: Simple names
USERNAME=your_username
PASSWORD=your_password

# Option 2: Prefixed names (avoids conflicts with other tools)
# OSPF_LINT_USERNAME=your_username
# OSPF_LINT_PASSWORD=your_password
